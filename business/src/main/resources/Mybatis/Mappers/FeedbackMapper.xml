<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jayce.vexis.business.dao.FeedbackDao">
    <insert id="insertFeedback" parameterType="feedbackBean">
        insert into feedback values (#{feedbackID}, #{userName}, #{userID}, #{type}, #{title},
                                     #{content}, #{createTime}, #{support}, #{against})
    </insert>

    <select id="getFeedback" resultType="feedbackBean">
        select * from feedback
    </select>

    <update id="supportFeedback">
        update feedback set support = support + #{count} where feedbackID = #{feedbackId}
    </update>

</mapper>